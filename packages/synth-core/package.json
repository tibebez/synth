{
	"name": "@synth/core",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --watch --dts",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/google": "latest",
		"@libsql/client": "^0.17.0",
		"@neondatabase/serverless": "^1.0.2",
