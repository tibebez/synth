		"ai": "latest",
		"mssql": "^12.2.0",
		"mysql2": "^3.18.2",
		"pg": "^8.19.0",
		"redis": "^5.11.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@synth/config": "workspace:*",
		"@types/bun": "^1.3.10",
		"@types/mssql": "^9.1.9",
		"@types/pg": "^8.18.0",
		"bun-types": "^1.3.10",
		"tsup": "^8.0.0",
		"typescript": "catalog:"
	}
